{
  "manifest_version": 3,
  "name": "EcoLogic ScholarMate Autofill",
  "version": "1.0.0",
  "description": "Autofill your verified scholar profile into government and corporate scholarship portals instantly.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:8080/*",
    "https://*.gov.in/*",
    "https://scholarships.gov.in/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
